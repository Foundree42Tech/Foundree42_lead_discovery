# PostgreSQL — injected automatically by DO Managed Database add-on
DATABASE_URL=postgresql://user:pass@localhost:5432/foundree42

# Session signing secret — generate a random string, keep it private
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Encryption key for secrets at rest (Salesforce tokens, stored API keys).
# Optional — falls back to SESSION_SECRET if unset. Set a dedicated value for
# key separation. Generate the same way as SESSION_SECRET.
# WARNING: changing this (or SESSION_SECRET, if this is unset) makes existing
# encrypted secrets unreadable — users must re-enter API keys and reconnect Salesforce.
ENCRYPTION_KEY=

# Salesforce login host — use https://test.salesforce.com for sandbox orgs.
# Optional — defaults to https://login.salesforce.com.
SF_LOGIN_URL=

# Resend — email verification and password reset
# Get your key at resend.com — domain foundree42.com must be verified
RESEND_API_KEY=re_...
NEXT_PUBLIC_APP_URL=https://your-app.ondigitalocean.app

# Salesforce OAuth — create a Connected App in Salesforce Setup
# Enable OAuth, scope: api + refresh_token, callback URL must match SF_CALLBACK_URL
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret
SF_CALLBACK_URL=https://your-app.ondigitalocean.app/api/auth/salesforce/callback
